---
import '../styles/global.css';

const response = await fetch("https://docs.google.com/spreadsheets/d/e/2PACX-1vS0RcSqNrtz0tgRAK0Qv3HxxVN3MhdJXvf14sXoJYceTef987fXhwmZWGiG49khJvxhbLMWgmQUNHbS/pub?output=csv");
const text = await response.text();
const rows = text.split("\n").map(r => r.split(","));

interface ImageModule {
    default: string;
}
const images = import.meta.glob<ImageModule>('../src/assets/img/*.{jpeg,jpg,png,gif,svg}', { 
    eager: true 
});

const projects = rows.slice(1)
                    .slice(-5)
                    .reverse()
                    .map(([imgName, title, description, link, badge, category, date]) => {
    const imgPath = `/src/assets/img/${imgName.trim()}`;
    const imgAssets = images[imgPath];

    return {
        img: imgAssets ? imgAssets.default : imgName,
        title, description, link, badge, category, date
    };
});
---

<div class="cards">
    {projects.map(project => (
        <div class="card">
            <a href={project.link} target="_blank">
                <img src={project.img} alt={project.title} />
                <p class="date">{project.date}</p>
                <div class="info">
                    <p class="category">{project.category}</p>
                    <h2>{project.title}</h2>
                    <p class="badge">{project.badge}</p>
                    <p>{project.description}</p>
                </div>
            </a>
        </div>
    ))}
</div>

<style>
    div {
        width: 100%;
        height: auto;
        padding: 0;
        border-radius: 8px;
    }
    
    a {
        text-decoration: none;
        color: inherit;
    }
    
    img {
        height: 200px;
        object-fit: cover;
        width: 100%;
        border-top-left-radius: 5px;
        border-top-right-radius: 5px;
        filter: grayscale(90%);
    }

    .info {
        padding: 1rem;
        width: fit-content;
    }

    .info h2 {
        line-height: 100%;
        margin: .5rem 0;
        color: var(--color-bl);
    }

    .info p {
        margin: .5rem 0 0;
        color: var(--color-bl);
        line-height: 1.2rem;
        opacity: 0;
        transform: translateY(10px);
        transition: all 0.3s ease;
    }

    .info .category {
        font-size: 0.8rem;
        font-weight: 600;
        text-transform: uppercase;
        color: var(--color-vio-2);
        margin: 0;
    }
    
    .info .badge {
        font-size: 0.75rem;
        font-weight: 500;
        color: var(--color-bl);
        margin: 0.25rem 0;
    }
    
    .cards {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        width: auto;
        gap: 1rem;
        margin: 2rem 4rem;
        padding: 2rem;
        justify-items: center;
        align-items: start;
        background-color: var(--color-bg-transp);
    }

    .card {
        height: 100%;
        background-color: var(--color-ng);
        transition: all 0.3s ease;
    }

    .card a {
        position: relative;
    }

    .date {
        position: absolute;
        font-size: 0.75rem;
        font-weight: 500;
        top: -10.85rem;
        right: 11px;
        background: linear-gradient(90deg, var(--color-vio-2), #dd54dd83);
        padding: .25rem .5rem;
        border-radius: 5px;
        color: var(--color-bl);
        opacity: 0;
        transform: translateY(20px);
        transition: all .3s ease;
        transition-delay: 0.5s;
    }

    
    div.card:hover {
        transform: translateY(-4px);
        background-color: var(--color-bl);
    }
    div.card:hover h2,
    div.card:hover p {
        color: var(--color-ng);
        opacity: 1;
        transform: translateY(0);
    }
    div.card:hover .date {
        background: var(--color-bl);
        color: var(--color-ng);
        opacity: 1;
        transform: translateY(0px);
    }
    div.card:hover img {
        filter: grayscale(0%);
    }
</style>