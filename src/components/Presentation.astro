---
import '../styles/global.css';
---
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Presentación</title>
    </head>
    <section class="presentation">
        <div class="video-container">
            <video autoplay muted loop id="video-hero">
                <source src="/video/Marcas-Animadas-2024.mp4" type="video/mp4">
            </video>
        </div>
        <div class="presentation-content">
            <h1>Nahuel Beck</h1>
            <p>Diseño para el universo impreso y digital.</p>
        </div>
    </section>
</html>

<style>
    body {
        margin: 0;
        padding: 0;
    }
    section {
        text-align: center;
    }
    
    h1 {
        font-weight: 100;
    }
    
    p {
        font-weight: 300;
    }
    
    .presentation {
        position: relative;
        height: 100vh;
    }

    .video-container {
        position: relative;
        width: 100%;
        height: 100%;
        z-index: -1;
        overflow: hidden;
    }

    #video-hero {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        min-width: 100%;
        min-height: 100%;
        z-index: -1;
        object-fit: cover;
    }

    .presentation-content {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        z-index: 1;
    }
</style>